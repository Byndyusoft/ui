---
to: "<%= hasStories ? `components/${h.changeCase.paramCase(name)}/src/${name}.stories.tsx` : null %>"
---
import React from 'react';
import { StoryObj } from '@storybook/react';
import { I<%= name %>Props } from './<%= name %>.types';
import <%= name %> from './<%= name %>';

const Template = (args: I<%= name %>Props): JSX.Element => <<%= name %> {...args}/>;

export const <%= name %>Story: StoryObj<\typeof Template> = {
    name: 'Story name',
    render: Template,
    args: {}
};

export default {
    title: 'components/<%= name %>
};
