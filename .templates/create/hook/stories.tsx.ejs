---
to: "<%= hasStories ? `hooks/${h.changeCase.paramCase(name)}/src/${name}.stories.tsx` : null %>"
---
import React from 'react';
import { StoryObj } from '@storybook/react';
import <%= name %> from './<%= name %>';

const Template = (...args): React.ReactNode => <HookStory {...args} />;

export const <%= name %>Story: StoryObj<\typeof Template> = {
    name: 'Story name',
    render: Template,
    args: {}
};

export default {
    title: 'hooks/<%= name %>',
    argTypes: {}
};
