{
  "name": "@byndyusoft-ui/modals-provider",
  "version": "0.1.1",
  "description": "Byndyusoft UI Modals Provider React Component",
  "keywords": [
    "byndyusoft",
    "byndyusoft-ui",
    "react",
    "modals"
  ],
  "author": "Dmitrii Maletskii <maleckij@byndyusoft.ru>",
  "homepage": "https://github.com/Byndyusoft/ui/tree/master/components/ModalsProvider#readme",
  "license": "ISC",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byndyusoft/ui.git"
  },
  "scripts": {
    "build": "rollup --config",
    "clean": "rimraf dist",
    "lint:check": "npm run eslint:check && npm run prettier:check && npm run stylelint:check",
    "lint:fix": "npm run eslint:fix && npm run prettier:fix && npm run stylelint:fix",
    "eslint:check": "eslint src --config ../../eslint.config.mjs",
    "eslint:fix": "eslint src --config ../../eslint.config.mjs --fix",
    "prettier:check": "prettier --check '**/*.{ts,tsx,css,scss,json}' '!**/dist/**'",
    "prettier:fix": "prettier --write '**/*.{ts,tsx,css,scss,json}' '!**/dist/**'",
    "stylelint:check": "stylelint '**/*.{css,scss}' --allow-empty-input",
    "stylelint:fix": "stylelint '**/*.{css,scss}' --fix --allow-empty-input"
  },
  "bugs": {
    "url": "https://github.com/Byndyusoft/ui/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
