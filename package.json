{
  "name": "root",
  "packageManager": "npm@10.2.4",
  "private": true,
  "workspaces": [
    "components/*",
    "hooks/*",
    "packages/*",
    "services/*",
    "styles/*"
  ],
  "version": "0.1.0",
  "description": "Byndyusoft React UI Library",
  "main": "lib/index.js",
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean",
    "lint": "turbo lint",
    "test": "turbo test",
    "lint:check": "lerna run lint:check",
    "lint:fix": "lerna run lint:fix",
    "eslint:check": "lerna run eslint:check",
    "eslint:fix": "lerna run eslint:fix",
    "stylelint:check": "lerna run stylelint:check",
    "stylelint:fix": "lerna run stylelint:fix",
    "prettier:check": "lerna run prettier:check",
    "prettier:fix": "lerna run prettier:fix",
    "postinstall": "(husky install) || true",
    "build-storybook": "storybook build --disable-telemetry",
    "start": "storybook dev -p 6009"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byndyusoft/ui.git"
  },
  "keywords": [
    "byndyusoft",
    "react",
    "components",
    "hooks"
