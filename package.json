{
  "name": "root",
  "packageManager": "npm@10.2.4",
  "private": true,
  "workspaces": [
    "components/*",
    "hooks/*",
    "packages/*",
    "services/*",
    "styles/*"
  ],
  "version": "0.1.0",
  "description": "Byndyusoft React UI Library",
  "main": "lib/index.js",
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint:check": "turbo lint:check",
    "lint:fix": "turbo lint:fix",
    "eslint:check": "turbo eslint:check",
    "eslint:fix": "turbo eslint:fix",
    "stylelint:check": "turbo stylelint:check",
    "stylelint:fix": "turbo stylelint:fix",
    "prettier:check": "turbo prettier:check",
    "prettier:fix": "turbo prettier:fix",
    "postinstall": "(husky install) || true",
    "build-storybook": "storybook build --disable-telemetry",
    "start": "storybook dev -p 6009"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byndyusoft/ui.git"
  },
  "keywords": [
    "byndyusoft",
    "react",
    "components",
    "hooks"
  ],
  "author": "Byndyusoft Frontend Stream <frontend@byndyusoft.com>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Byndyusoft/ui/issues"
  },
  "homepage": "https://github.com/Byndyusoft/ui#readme",
  "devDependencies": {
    "@byndyusoft/eslint-config": "^2.0.0",
    "@byndyusoft/stylelint-config": "^1.0.0",
    "@commitlint/cli": "^17.1.2",
    "@commitlint/config-conventional": "^17.1.0",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@storybook/addon-a11y": "^8.6.4",
    "@storybook/addon-actions": "^8.6.4",
    "@storybook/addon-essentials": "^8.6.4",
    "@storybook/react": "^8.6.4",
    "@storybook/react-vite": "^8.6.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^12.1.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/classnames": "^2.3.1",
    "@types/estree": "^1.0.5",
    "@types/react": "^17.0.21",
    "@types/react-dom": "^17.0.17",
    "classnames": "^2.3.1",
    "eslint": "8.22.0",
    "happy-dom": "^17.4.4",
    "husky": "^8.0.1",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^26.0.0",
    "lint-staged": "^13.0.3",
    "prettier": "^2.7.1",
    "react": "^17.0.2",
    "rollup": "^4.41.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.89.0",
    "storybook": "^8.6.4",
    "stylelint": "^16.14.1",
    "turbo": "^2.4.4",
    "typescript": "^4.9.5",
    "vite": "^6.2.1",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^3.0.8"
  },
  "peerDependencies": {
    "classnames": "^2.3.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "dependencies": {
    "react-frame-component": "^5.2.6"
  }
}
